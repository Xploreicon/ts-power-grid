# Supabase
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL_HERE
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# Paystack
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=YOUR_PAYSTACK_PUBLIC_KEY_HERE
PAYSTACK_SECRET_KEY=YOUR_PAYSTACK_SECRET_KEY_HERE

# Termii (SMS)
TERMII_API_KEY=YOUR_TERMII_API_KEY_HERE
TERMII_SENDER_ID=N-Alert

# Auth — synthetic email suffix for phone-based auth (Option B).
# Must be a domain you control or a non-routable placeholder.
PHONE_AUTH_EMAIL_SUFFIX=phone.tspowergrid.local

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
