# Supabase
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL_HERE
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# Paystack
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=YOUR_PAYSTACK_PUBLIC_KEY_HERE
PAYSTACK_SECRET_KEY=YOUR_PAYSTACK_SECRET_KEY_HERE
# Optional — defaults to PAYSTACK_SECRET_KEY if unset. Paystack uses the
# same key for webhook HMAC-SHA512 signing by default.
PAYSTACK_WEBHOOK_SECRET=
# Where Paystack redirects the user after a checkout. Leave unset to default
# to `${NEXT_PUBLIC_APP_URL}/payments/callback`.
PAYSTACK_CALLBACK_URL=

# Termii (SMS)
TERMII_API_KEY=YOUR_TERMII_API_KEY_HERE
TERMII_SENDER_ID=N-Alert

# WhatsApp Business Cloud API (Meta, Graph v20.0)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
# Free-form token we pick; Meta echoes it back on webhook setup.
WHATSAPP_VERIFY_TOKEN=

# Vercel Cron shared secret (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# Web Push (VAPID)
# Generate with `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@tspowergrid.com

# Resend (Email)
RESEND_API_KEY=

# Auth — synthetic email suffix for phone-based auth (Option B).
# Must be a domain you control or a non-routable placeholder.
PHONE_AUTH_EMAIL_SUFFIX=phone.tspowergrid.local

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
